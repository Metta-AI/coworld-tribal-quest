{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/metta/main/packages/cogames/src/cogames/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "tribal_quest",
    "version": "0.1.0",
    "description": "An adventurer-focused Coworld surface that runs on the shared Tribal Fortress grid world.",
    "owner": "treeform@softmax.com",
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens"
      ],
      "properties": {
        "tokens": {
          "description": "One Quest adventurer connection token per player slot.",
          "type": "array",
          "minItems": 0,
          "maxItems": 64,
          "items": {
            "type": "string",
            "minLength": 0
          },
          "default": []
        },
        "fortressEnginePath": {
          "description": "Local path to a coworld-tribal-fortress checkout or package. If empty, TRIBAL_FORTRESS_PATH or ../coworld-tribal-fortress is used.",
          "type": "string",
          "default": ""
        },
        "seed": {
          "description": "Random seed.",
          "type": "integer",
          "minimum": 0,
          "default": 726896
        },
        "maxTicks": {
          "description": "Maximum Fortress ticks before starting a fresh game, where 0 means no tick limit.",
          "type": "integer",
          "minimum": 0,
          "default": 18000
        },
        "maxGames": {
          "description": "Maximum fresh games before shutdown, where 0 means no game limit.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "names",
        "scores"
      ],
      "properties": {
        "names": {
          "description": "One player name or address per connected adventurer slot.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scores": {
          "description": "Quest adventurer score per connected slot.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "survival_ticks": {
          "description": "Per-adventurer survival ticks.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "distance_walked": {
          "description": "Per-adventurer distance walked.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "civilizations": {
          "description": "Current civilization metadata for each adventurer slot.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "protocols": {
      "player": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/coworld-tribal-quest/blob/main/plan.md"
      },
      "engine_runtime": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/coworld-tribal-fortress/blob/main/tribal_village_env/coworld/docs/engine_runtime_contract.md"
      }
    },
    "runnable": {
      "type": "game",
      "image": "ghcr.io/metta-ai/coworld-tribal-quest:latest",
      "run": [
        "/bin/tribal_quest",
        "--address:0.0.0.0",
        "--port:8080"
      ]
    },
    "docs": {
      "readme": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/coworld-tribal-quest/blob/9f1452a9f8fe820df7a0fdb56a5872534251d509/README.md"
      }
    }
  },
  "player": [],
  "variants": [
    {
      "id": "smoke",
      "name": "Smoke",
      "game_config": {
        "seed": 726896,
        "maxTicks": 300,
        "maxGames": 1
      },
      "description": "Short deterministic Tribal Quest adventurer configuration used for manifest checks."
    }
  ],
  "certification": {
    "variant_id": "smoke",
    "players": []
  }
}
