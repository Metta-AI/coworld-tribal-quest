{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/metta/main/packages/cogames/src/cogames/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "tribal_quest",
    "version": "0.1.0",
    "description": "A cooperative BitWorld expedition RPG where players talk, choose tank/DPS/healer gear, and push a shared frontier to the right.",
    "owner": "treeform@softmax.com",
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens"
      ],
      "properties": {
        "tokens": {
          "description": "One connection token per player slot, indexed by slot.",
          "type": "array",
          "minItems": 0,
          "maxItems": 64,
          "items": {
            "type": "string",
            "minLength": 0
          },
          "default": []
        },
        "seed": {
          "description": "Random seed.",
          "type": "integer",
          "minimum": 0,
          "default": 726896
        },
        "maxTicks": {
          "description": "Maximum simulation ticks before starting a fresh game, where 0 means no tick limit.",
          "type": "integer",
          "minimum": 0,
          "default": 18000
        },
        "maxGames": {
          "description": "Maximum fresh games before shutdown, where 0 means no game limit.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "names",
        "scores",
        "hearts",
        "distance_walked",
        "frontier_tiles",
        "personal_frontier_tiles",
        "roles",
        "damage_done",
        "healing_done",
        "damage_blocked",
        "messages_sent"
      ],
      "properties": {
        "names": {
          "description": "One player name or address per player slot.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scores": {
          "description": "Shared team frontier score per player slot.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "hearts": {
          "description": "One remaining life count per player slot.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "distance_walked": {
          "description": "One total distance walked value per player slot.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "frontier_tiles": {
          "description": "Shared farthest rightward progress beyond the safe origin, in tiles.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "personal_frontier_tiles": {
          "description": "Per-player farthest rightward progress beyond the safe origin, in tiles.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "roles": {
          "description": "Current role for each player slot.",
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "unarmed",
              "tank",
              "dps",
              "healer"
            ]
          }
        },
        "damage_done": {
          "description": "Per-player monster damage dealt.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "healing_done": {
          "description": "Per-player healing applied to allies.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "damage_blocked": {
          "description": "Per-player damage prevented with tank guard.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "messages_sent": {
          "description": "Per-player public chat messages accepted by the server.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "protocols": {
      "player": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md",
      "global": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md",
      "reward": "https://github.com/Metta-AI/bitworld/blob/master/docs/reward_v1.md"
    },
    "runnable": {
      "type": "game",
      "image": "ghcr.io/metta-ai/coworld-tribal-quest:latest",
      "run": ["/bin/tribal_quest", "--address:0.0.0.0", "--port:8080"]
    }
  },
  "player": [
    {
      "id": "konrad",
      "name": "konrad",
      "description": "Coworld player for tribal_quest.",
      "runnable": {
        "type": "player",
        "image": "ghcr.io/metta-ai/coworld-tribal-quest-konrad:latest",
        "run": ["/bin/konrad", "--address:host.docker.internal", "--port:2000"]
      }
    }
  ],
  "variants": [
    {
      "id": "smoke",
      "name": "Smoke",
      "game_config": {
        "seed": 726896,
        "maxTicks": 300,
        "maxGames": 1
      },
      "description": "Short deterministic tribal_quest configuration used for manifest checks."
    }
  ],
  "certification": {
    "variant_id": "smoke",
    "players": [
      {
        "player_id": "konrad",
        "initial_params": {
          "name": "slot_0"
        }
      },
      {
        "player_id": "konrad",
        "initial_params": {
          "name": "slot_1"
        }
      }
    ]
  }
}
